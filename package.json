    "browser-sync": "^3.0.4",
    "npm-check-updates": "^22.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4"
  },
